# ============================================================
# LeadBoost - Environment Variables
# ============================================================
# Copy this file to .env and fill in all required values.
# Variables marked [REQUIRED] must be set for the app to run.
# Variables marked [REQUIRED-PROD] must be set in production.
# Variables marked [OPTIONAL] have sensible defaults.
# ============================================================

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# [REQUIRED] PostgreSQL connection string
# For local dev: postgresql://postgres:password@localhost:5432/leadboost
# For production: Use Neon, Supabase, AWS RDS, etc.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/leadboost

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
# [OPTIONAL] Server port (default: 5000)
PORT=5000

# [OPTIONAL] Node environment (development | production)
NODE_ENV=development

# [REQUIRED-PROD] Your production domain URL (used for OAuth callbacks, webhooks, CORS, Socket.IO)
# Example: https://app.leadboostapp.ai
APP_URL=http://localhost:5000

# [OPTIONAL] Additional allowed CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://admin.leadboostapp.ai,https://staging.leadboostapp.ai

# [REQUIRED-PROD] Strong random string for Express session encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ------------------------------------------------------------
# FIREBASE (Authentication)
# ------------------------------------------------------------
# [REQUIRED] Client-side Firebase config (exposed to browser via VITE_ prefix)
# Get these from: Firebase Console > Project Settings > General > Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# [REQUIRED] Server-side Firebase Admin SDK credentials
# Get these from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ------------------------------------------------------------
# AI SERVICES
# ------------------------------------------------------------
# [REQUIRED] Google Gemini API key
# Used for: image generation, brand essence, logo generation, post generation, editorial mode
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# [REQUIRED] OpenAI API key
# Used for: content strategy, help chat, sentiment analysis, DALL-E images
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ------------------------------------------------------------
# CLOUDINARY (Image/Video Storage)
# ------------------------------------------------------------
# [REQUIRED] Cloudinary credentials
# Get from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# [REQUIRED] Client-side Cloudinary config (exposed to browser via VITE_ prefix)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ------------------------------------------------------------
# META / FACEBOOK (Social Media Integration)
# ------------------------------------------------------------
# [REQUIRED for social features] Meta App credentials
# Get from: https://developers.facebook.com/ > Your App > Settings > Basic
FB_APP_ID=
FB_APP_SECRET=

# [OPTIONAL] Instagram App credentials (defaults to FB_APP_ID/SECRET if shared app)
IG_APP_ID=
IG_APP_SECRET=

# [OPTIONAL] WhatsApp Business configuration ID
WHATSAPP_CONFIG_ID=

# [OPTIONAL] Meta webhook verification token (default: leadboost_meta_webhook)
META_VERIFY_TOKEN=leadboost_meta_webhook

# ------------------------------------------------------------
# STRIPE (Payments & Billing)
# ------------------------------------------------------------
# [REQUIRED for billing] Stripe API keys
# Get from: Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# [REQUIRED for billing] Stripe webhook signing secret
# Get from: Stripe Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------
# LIGHTSPEED POS
# ------------------------------------------------------------
# [OPTIONAL] Lightspeed X-Series POS OAuth credentials
# Get from: https://www.lightspeedhq.com/developers/
LIGHTSPEED_CLIENT_ID=
LIGHTSPEED_CLIENT_SECRET=

# ------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------
# [REQUIRED-PROD] AES-256 encryption key for POS tokens (exactly 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
POS_ENCRYPTION_KEY=

# ------------------------------------------------------------
# GOOGLE MAPS & FONTS (Client-side)
# ------------------------------------------------------------
# [OPTIONAL] Google Maps API key for address autocomplete
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=

# [OPTIONAL] Google Fonts API key for font selector
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_FONTS_API_KEY=

# ------------------------------------------------------------
# WHATSAPP BAILEYS (Unofficial API)
# ------------------------------------------------------------
# [OPTIONAL] Enable Baileys WhatsApp integration (set to "true" to enable)
# WARNING: This uses an unofficial API and may violate WhatsApp ToS
ENABLE_BAILEYS=false

# ------------------------------------------------------------
# REPLIT-SPECIFIC (Only needed when deployed on Replit)
# ------------------------------------------------------------
# These are auto-set by Replit. Only configure manually if deploying elsewhere.
# REPLIT_DOMAINS=
# REPLIT_DEV_DOMAIN=
# REPLIT_DEPLOYMENT=
# REPLIT_CONNECTORS_HOSTNAME=
# REPL_IDENTITY=
# REPL_ID=
# WEB_REPL_RENEWAL=
