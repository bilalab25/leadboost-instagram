    {
      "parameters": {
        "url": "=https://graph.facebook.com/v24.0/{{ $json.account_id }}/insights",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "metric",
              "value": "page_media_view,page_post_engagements,page_posts_impressions_unique"
            },
            {
              "name": "period",
              "value": "month"
            },
            {
              "name": "access_token",
              "value": "={{ $json.access_token }}"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        -960,
        0
      ],
      "id": "fb_insights",
      "name": "Facebook Insights"
    },
    {
      "parameters": {
        "jsCode": "// Calcular métricas promedio de Facebook\nconst fb = $json.data || [];\nconst get = name => fb.find(m => m.name === name)?.values.map(v => v.value) || [];\nconst avg = arr => arr.length ? arr.reduce((a,b)=>a+b,0)/arr.length : 0;\nconst avgEng = avg(get('page_post_engagements'));\nconst avgReach = avg(get('page_posts_impressions_unique'));\nconst avgViews = avg(get('page_media_view'));\n\n// Frecuencia según tasa de engagement\nconst rate = avgEng / (avgReach || 1);\nlet frequency = '1 publicación por semana';\nif (rate > 0.05) frequency = '3 publicaciones por semana';\nif (rate > 0.08) frequency = '5 publicaciones por semana';\n\n// Días según frecuencia\nlet days = ['wed'];\nif (frequency.includes('3')) days = ['mon','wed','fri'];\nif (frequency.includes('5')) days = ['mon','tue','wed','thu','fri'];\n\n// Horas según engagement\nlet hours = ['12:00','14:00'];\nif (rate > 0.05) hours = ['11:00','13:00'];\nif (rate > 0.08) hours = ['10:00','12:00'];\n\nreturn [{ json: {\n  platform: 'facebook',\n  frequency_days: frequency,\n  days_week: days,\n  best_hours: hours,\n  insights_data: {\n    avg_engagement_rate: rate,\n    avg_reach: avgReach,\n    avg_views: avgViews\n  }\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -720,
        0
      ],
      "id": "fb_besttime",
      "name": "Facebook Metrics + Best Time"
    },
    {
      "parameters": {
        "url": "=https://graph.facebook.com/v24.0/{{ $json.account_id }}/insights",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "metric",
              "value": "reach,profile_views,accounts_engaged,total_interactions"
            },
            {
              "name": "period",
