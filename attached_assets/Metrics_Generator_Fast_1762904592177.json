      "id": "ig_insights2",
      "name": "Instagram Insights2"
    },
    {
      "parameters": {
        "jsCode": "// Combinar métricas de Instagram\nconst metrics = [].concat($items('Instagram Insights1')[0].json.data || [], $items('Instagram Insights2')[0].json.data || []);\nconst get = name => metrics.find(m => m.name === name)?.values?.map(v => v.value) || [];\nconst avg = arr => arr.length ? arr.reduce((a,b)=>a+b,0)/arr.length : 0;\nconst avgReach = avg(get('reach'));\nconst avgProfileViews = avg(get('profile_views'));\nconst avgAccountsEngaged = avg(get('accounts_engaged'));\nconst avgInteractions = avg(get('total_interactions'));\nconst avgFollowers = avg(get('follower_count'));\n\nconst engagementRate = avgAccountsEngaged / (avgReach || 1);\nconst interactionRate = avgInteractions / (avgReach || 1);\n\n// Frecuencia\nlet frequency = '1 publicación por semana';\nif (engagementRate > 0.04 || interactionRate > 0.03) frequency = '3 publicaciones por semana';\nif (engagementRate > 0.08 || interactionRate > 0.06) frequency = '5 publicaciones por semana';\n\n// Días y horas\nlet days = ['wed'];\nif (frequency.includes('3')) days = ['tue','thu','sat'];\nif (frequency.includes('5')) days = ['mon','tue','wed','thu','fri'];\nlet hours = ['10:00','12:00'];\nif (engagementRate > 0.05) hours = ['11:00','13:00'];\nif (engagementRate > 0.08) hours = ['09:00','11:00'];\n\nreturn [{ json: {\n  platform: 'instagram',\n  frequency_days: frequency,\n  days_week: days,\n  best_hours: hours,\n  insights_data: {\n    avg_engagement_rate: engagementRate,\n    avg_reach: avgReach,\n    avg_profile_views: avgProfileViews,\n    avg_accounts_engaged: avgAccountsEngaged,\n    avg_interactions: avgInteractions,\n    avg_followers: avgFollowers,\n    interaction_rate: interactionRate\n  }\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -720,
        400
      ],
      "id": "ig_besttime",
      "name": "Instagram Metrics + Best Time"
    },
